  "keyFeatures": [
    "600+ pre-built connectors for APIs, databases, files, and data warehouses",
    "No-code Connector Builder UI for building custom connectors without code",
    "Low-code CDK (Connector Development Kit) for Python-based connector development",
    "Change Data Capture (CDC) support for real-time database replication",
    "Typing and deduplication (T+D) for clean, typed data in destinations",
    "Incremental and full-refresh sync modes",
    "Self-hosted (Kubernetes/Helm) and Airbyte Cloud managed deployment options",
    "Self-Managed Enterprise edition with SSO, RBAC, and advanced security",
    "PyAirbyte library for programmatic data extraction in Python/Jupyter",
    "Terraform provider for infrastructure-as-code management",
    "Native orchestration integrations with Airflow, Prefect, Dagster, and Kestra",
    "Schema change management with automatic detection and handling"
  ],
  "publicApiSurface": [
    "GET /v1/sources — List sources",
    "POST /v1/sources — Create a source",
    "GET /v1/destinations — List destinations",
    "POST /v1/destinations — Create a destination",
    "GET /v1/connections — List connections",
    "POST /v1/connections — Create a connection",
    "POST /v1/jobs — Trigger a sync job",
    "GET /v1/jobs/{jobId} — Get job status",
    "PyAirbyte: ab.get_source(name, config) — Get a source connector",
    "PyAirbyte: source.get_records(stream) — Read records from a stream",
    "PyAirbyte: ab.get_available_connectors() — List available connectors",
    "Terraform: airbyte_source resource",
    "Terraform: airbyte_destination resource",
    "Terraform: airbyte_connection resource",
    "Airbyte Protocol: spec() — Return connector configuration schema",
    "Airbyte Protocol: check() — Validate connector credentials",
    "Airbyte Protocol: discover() — Return source catalog/schema",
    "Airbyte Protocol: read() — Read records from source",
    "Airbyte Protocol: write() — Write records to destination"
  ]
}
